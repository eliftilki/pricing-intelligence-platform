APP_ENV=development
APP_DEBUG=true

# Shared database
DATABASE_URL=postgresql://user:password@localhost:5432/pricing_intelligence
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# API service
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
AGENT_SERVICE_URL=http://localhost:8001
DATA_INGESTION_SERVICE_URL=http://localhost:8004
API_REQUEST_TIMEOUT_SECONDS=30
AGENT_REQUEST_TIMEOUT_SECONDS=240
DATA_INGESTION_REQUEST_TIMEOUT_SECONDS=180

# Comma-separated origins, or * for local development.
CORS_ORIGINS=*

# Data ingestion service
COLLECTOR_TIMEOUT_SECONDS=60
